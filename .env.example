# AI Video Generation Service APIs
# Get your API keys from the respective services

# AI/ML API (unified access to multiple AI models)
AIML_API_KEY=your_aiml_api_key_here

# Individual Service APIs (optional if using AI/ML API)
RUNWAY_API_KEY=your_runway_api_key
PIKA_API_KEY=your_pika_api_key
KLING_API_KEY=your_kling_api_key
MINIMAX_API_KEY=your_minimax_api_key
LUMA_API_KEY=your_luma_api_key
GOOGLE_VEO_API_KEY=your_google_veo_api_key

# OpenAI for text generation and content ideas
OPENAI_API_KEY=your_openai_api_key

# Content Generation Settings
DEFAULT_VIDEO_DURATION=10
ASPECT_RATIO=9:16
VIDEO_QUALITY=1080p
DAILY_POST_COUNT=3
CONTENT_QUEUE_SIZE=20

# Posting Schedule (24-hour format)
OPTIMAL_POST_TIMES=09:00,15:00,21:00
TIMEZONE=UTC

# TikTok Account Settings
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_COOKIES_FILE=cookies/tiktok_cookies.txt

# Storage Paths
VIDEOS_DIR=./generated_videos
QUEUE_DIR=./video_queue
LOGS_DIR=./logs
CONFIG_DIR=./config
DATA_DIR=./data

# Database Configuration
DATABASE_URL=sqlite:///./tiktok_bot.db

# Redis Configuration (for task queue)
REDIS_URL=redis://localhost:6379/0

# Content Generation
ENABLE_AI_CAPTIONS=true
ENABLE_HASHTAG_RESEARCH=true
ENABLE_TRENDING_ANALYSIS=true
MAX_HASHTAGS=10

# Safety and Rate Limiting
MAX_DAILY_UPLOADS=5
UPLOAD_DELAY_MIN=30
UPLOAD_DELAY_MAX=180
ENABLE_HUMANLIKE_BEHAVIOR=true

# Analytics and Monitoring
ENABLE_ANALYTICS=true
ANALYTICS_DB_URL=sqlite:///./analytics.db
TRACK_ENGAGEMENT=true
TRACK_PERFORMANCE=true

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/tiktok_bot.log
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# Error Handling
MAX_RETRIES=3
RETRY_DELAY=30
ENABLE_NOTIFICATIONS=false
WEBHOOK_URL=your_webhook_url

# Development Settings
DEBUG_MODE=false
TEST_MODE=false
DRY_RUN=false

# Proxy Settings (optional)
USE_PROXY=false
PROXY_URL=http://username:password@proxy.com:port
PROXY_ROTATION=false

# Content Themes
DEFAULT_THEME=motivational
AVAILABLE_THEMES=motivational,educational,trending,abstract,nature,urban

# Video Processing
FFMPEG_PATH=ffmpeg
ENABLE_GPU_ACCELERATION=false
VIDEO_CODEC=h264
AUDIO_CODEC=aac

# Social Media Integration
ENABLE_CROSS_POSTING=false
INSTAGRAM_USERNAME=your_instagram_username
YOUTUBE_SHORTS_CHANNEL=your_youtube_channel

# Captcha Solving (optional)
CAPTCHA_SOLVER_API_KEY=your_captcha_solver_key
CAPTCHA_SOLVER_SERVICE=2captcha

# Monitoring and Alerts
ENABLE_HEALTH_CHECKS=true
HEALTH_CHECK_INTERVAL=3600
ALERT_EMAIL=your_email@example.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password